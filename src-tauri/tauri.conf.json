{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent City",
  "version": "0.1.2",
  "identifier": "com.agentcity.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix apps/web run dev -- --host 127.0.0.1 --port 5174 --strictPort",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm --prefix apps/web run build",
    "frontendDist": "../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent City",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost https://raw.githubusercontent.com data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:34127 https:; font-src 'self' data:; media-src 'self' asset: http://asset.localhost https://asset.localhost blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["binaries/agent-city-server"],
    "resources": {
      "resources/server/": "server/",
      "resources/seed-data/": "seed-data/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
